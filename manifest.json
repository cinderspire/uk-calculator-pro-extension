{
  "manifest_version": 3,
  "name": "UK Calculator Pro - Tax, VAT & Salary",
  "version": "1.0.0",
  "description": "Quick UK tax, salary, VAT and unit calculations right in your browser. Updated for 2025/26 tax year.",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "browser_specific_settings": {
    "gecko": {
      "id": "uk-calculator-pro@ukcalculator.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": false,
        "private_browsing_allowed": false
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "UK Calculator Pro"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "homepage_url": "https://ukcalculator.com",
  "author": "UK Calculator (ukcalculator.com)"
}